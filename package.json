{
  "name": "impostor_js",
  "version": "3.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "dist/index.js",
      "types": "dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "author": "Carl Beattie <12beattiecastp@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/carlbeattie2000/impostor.js"
  },
  "scripts": {
    "clean": "rimraf dist node_modules",
    "build:clean": "rimraf dist",
    "build:main": "tsc --project tsconfig.build.json",
    "build": "run-s build:clean build:main",
    "test": "vitest",
    "format": "prettier --cache --write .",
    "release": "standard-version"
  },
  "keywords": [
    "nodejs",
    "fake_user_information",
    "fake_user_account_information",
    "json"
  ],
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^9",
    "@types/node": "^20.10.6",
    "csv-parse": "^5.0.4",
    "esbuild": "^0.19.11",
    "eslint": "^9.39.4",
    "eslint-config-airbnb-extended": "^3.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "glob": "^10.3.10",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "standard-version": "^9.5.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.1"
  },
  "packageManager": "pnpm@8.12.1"
}
